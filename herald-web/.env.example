# ─── Required ───────────────────────────────────────────────
HERALD_WEB_HOST=0.0.0.0
HERALD_WEB_PORT=8088

# The publicly reachable base URL of the portal. Used to build the
# Discord OAuth redirect URI and any absolute links emitted by the app.
# Examples:
#   http://192.168.1.50:8088       (static IP)
#   http://tower.local:8088        (mDNS)
#   https://herald.example.com     (reverse proxy with domain)
HERALD_WEB_BASE_URL=http://localhost:8088

# Path to the shared SQLite database. For dev, point at scheduler-test.db
# so the bot's real data stays untouched.
DB_PATH=data/scheduler.db

# Session cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ─── Discord OAuth (filled in during Phase 1) ──────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8088/auth/callback

# ─── AI (shared with the bot — same env var names) ─────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
LOCALAI_BASE_URL=
LOCALAI_MODEL=
LOCALAI_API_KEY=not-needed

# ─── Optional ──────────────────────────────────────────────
# Lock the portal to a single Discord guild (otherwise any user who
# shares a guild with the bot can log in).
ALLOWED_GUILD_ID=
